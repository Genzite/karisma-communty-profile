---
// src/components/CtaSection.astro
---

<section
    class="relative py-24 bg-black border-t border-white/5 overflow-hidden"
>
    <div
        class="absolute -top-20 -left-20 w-[400px] h-[400px] bg-purple-600/20 rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 container mx-auto px-6 text-center">
        <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-6">
            Siap Bergerak Bersama?
        </h2>
        <p class="text-gray-400 text-lg md:text-xl mb-12 max-w-xl mx-auto">
            Jadilah bagian dari perubahan. Bergabunglah dengan komunitas Karisma
            UAI dan mulai perjalanan dakwahmu hari ini.
        </p>

        <a
            href="#bergabung"
            class="inline-block px-10 py-4 bg-gradient-to-r from-purple-600 to-fuchsia-600 hover:from-purple-500 hover:to-fuchsia-500 text-white font-bold rounded-full text-lg shadow-[0_0_30px_rgba(168,85,247,0.4)] transition-all hover:scale-105 active:scale-95 mb-16"
        >
            Daftar Sekarang
        </a>

        <div class="flex flex-col items-center gap-6">
            <span
                class="text-white/40 text-sm tracking-[0.2em] uppercase font-bold"
                >Terhubung Dengan Kami</span
            >
            <div
                class="flex flex-wrap justify-center gap-6 md:gap-12 text-white"
            >
                <a
                    href="#"
                    class="flex items-center gap-2 hover:text-fuchsia-400 transition-colors"
                >
                    <span class="text-sm md:text-lg font-semibold"
                        >Instagram</span
                    >
                </a>
                <a
                    href="#"
                    class="flex items-center gap-2 hover:text-fuchsia-400 transition-colors"
                >
                    <span class="text-sm md:text-lg font-semibold">TikTok</span>
                </a>
                <a
                    href="#"
                    class="flex items-center gap-2 hover:text-fuchsia-400 transition-colors"
                >
                    <span class="text-sm md:text-lg font-semibold"
                        >WhatsApp</span
                    >
                </a>
                <a
                    href="#"
                    class="flex items-center gap-2 hover:text-fuchsia-400 transition-colors"
                >
                    <span class="text-sm md:text-lg font-semibold">YouTube</span
                    >
                </a>
            </div>
        </div>
    </div>
</section>
