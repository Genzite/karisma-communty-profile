</nav>

<script>
    // Gunakan astro:page-load agar script selalu berjalan meskipun pindah-pindah halaman
    document.addEventListener("astro:page-load", () => {
        const menuToggle = document.getElementById("menu-toggle");
        const mobileMenu = document.getElementById("mobile-menu");
        const menuIconPath = document.getElementById("menu-icon-path");
        const mobileLinks = document.querySelectorAll(".mobile-link");

        // Hentikan eksekusi jika salah satu elemen utama tidak ditemukan di halaman ini
        if (!menuToggle || !mobileMenu || !menuIconPath) return;

        let isMenuOpen = false;

        // Path SVG untuk animasi
        const iconHamburger = "M4 6h16M4 12h16m-7 6h7"; // Ikon bawaan Anda
        const iconClose = "M6 18L18 6M6 6l12 12"; // Ikon X (Tutup)

        function toggleMenu() {
            isMenuOpen = !isMenuOpen;

            if (isMenuOpen) {
                mobileMenu.classList.remove("opacity-0", "pointer-events-none");
                mobileMenu.classList.add("opacity-100", "pointer-events-auto");

                // Ubah SVG menjadi tanda silang dan putar sedikit tombolnya
                menuIconPath.setAttribute("d", iconClose);
                menuToggle.classList.add("rotate-90");

                document.body.style.overflow = "hidden";
            } else {
                mobileMenu.classList.remove(
                    "opacity-100",
                    "pointer-events-auto",
                );
                mobileMenu.classList.add("opacity-0", "pointer-events-none");

                // Kembalikan SVG ke bentuk semula
                menuIconPath.setAttribute("d", iconHamburger);
                menuToggle.classList.remove("rotate-90");

                document.body.style.overflow = "";
            }
        }

        // Mendaftarkan event listener pada tombol hamburger
        menuToggle.addEventListener("click", toggleMenu);

        // Mendaftarkan event listener pada setiap link di dalam menu mobile
        mobileLinks.forEach((link) => {
            link.addEventListener("click", () => {
                if (isMenuOpen) toggleMenu();
            });
        });
    });
</script>
